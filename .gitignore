# Downloads and generated assets (large, user-specific)
downloads/*
!downloads/.gitkeep
!downloads/_metadata/
downloads/_metadata/*
!downloads/_metadata/.gitkeep
assets/
client_packages/
packages/
logs/*
!logs/.gitkeep

# Scraper history (user-specific)
scraper/download_history.json

# Exported RPFs (large binary, user-specific)
new_dlc_exported/*
!new_dlc_exported/.gitkeep

# Node
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
.venv/
.env

# Archives (downloaded files)
*.zip
*.rar
*.7z

# GTA assets (large binary files)
*.yft
*.ytd
*.ydr
*.ydd
*.ymap
*.ytyp
*.rpf

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
*.swp
